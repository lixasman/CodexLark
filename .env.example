# CodexLark does not auto-load this file.
# Copy the values you need into your PowerShell session, user environment variables,
# or your own startup script before running the project.

# Required Feishu credentials
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=replace_me

# Optional Codex CLI override
CODEX_CLI_EXE=codex

# Optional default assistant working directory
COMMUNICATE_ASSISTANT_CWD=

# Optional image output directory
COMMUNICATE_FEISHU_IMAGE_DIR=.\Communicate

# Optional registry path
COMMUNICATE_SESSION_REGISTRY_PATH=.\logs\communicate\registry.json

# Optional Codex home override (falls back to CODEX_HOME or %USERPROFILE%\.codex)
COMMUNICATE_CODEX_HOME=

# Optional long-connection debug controls
COMMUNICATE_FEISHU_DEBUG=0
COMMUNICATE_FEISHU_DEBUG_LOG_PATH=.\logs\communicate\feishu-longconn-debug.log
COMMUNICATE_FEISHU_RAW_EVENT_DUMP_PATH=.\logs\communicate\feishu-longconn-raw-events.log
COMMUNICATE_FEISHU_INSTANCE_TAG=
